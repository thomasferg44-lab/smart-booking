# Supabase (server-side only — never expose the service role key in frontend code)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend (transactional email)
RESEND_API_KEY=your-resend-api-key

# Company / owner details
OWNER_EMAIL=owner@example.com
OWNER_NAME=Owner
COMPANY_NAME=Your Company
REPLY_TO_EMAIL=noreply@example.com
PRIMARY_COLOR=#21B7B5

# Admin dashboard gate (set per client) — checked by admin-bookings.js / admin-update.js
ADMIN_PASSWORD=set-a-strong-password

# Google Calendar sync (shared DropStack service-account credentials)
# GOOGLE_PRIVATE_KEY keeps its literal \n escapes on one line; code converts them.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: set to 'true' only while using the temporary test-calendar function.
ENABLE_TEST_CALENDAR=
